# Redirecionar URLs não-www para www
RewriteEngine on
RewriteCond %{HTTP_HOST} !^www\.gestou\.com\.br
RewriteRule (.*) http://www.gestou.com.br/$1 [R=301,L]
# CONFIGURAR UTILIZAÇÃO DO HTTPS
RewriteEngine On
RewriteCond %{SERVER_PORT} 80
RewriteRule ^(.*)$ https://www.gestou.com.br/$1 [R,L]

RewriteEngine on
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php
